# Firebase Web SDK — берётся из Project Settings → General → Your apps → Web app config
VITE_FIREBASE_API_KEY=replace_with_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:your-project-id:web:xxxx

# URL сервера (для локальной разработки оставить как есть)
VITE_SERVER_URL=http://localhost:3000
