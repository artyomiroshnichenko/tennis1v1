generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  firebaseId String?  @unique
  nickname   String   @unique
  role       Role     @default(USER)
  createdAt  DateTime @default(now())

  matches MatchPlayer[]
}

enum Role {
  USER
  ADMIN
}

model Match {
  id         String      @id @default(uuid())
  type       MatchType
  status     MatchStatus
  winnerId   String?
  sets       Json
  duration   Int?
  createdAt  DateTime    @default(now())
  finishedAt DateTime?

  players MatchPlayer[]
}

enum MatchType {
  ONLINE
  BOT
}

enum MatchStatus {
  FINISHED
  TECHNICAL_DEFEAT
}

model MatchPlayer {
  id       String  @id @default(uuid())
  matchId  String
  userId   String
  side     String
  isWinner Boolean

  match Match @relation(fields: [matchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

enum AuthSubjectType {
  GUEST
  USER
}

model RefreshToken {
  id        String          @id @default(uuid())
  tokenHash String          @unique
  subjectId String
  type      AuthSubjectType
  expiresAt DateTime
  createdAt DateTime        @default(now())
  /// Для GUEST: { "nickname": string }; для USER — null
  payload   Json?

  @@index([subjectId, type])
}
