# База данных
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# ВАЖНО: хост postgres — только внутри Docker-сети prod-compose (см. docker-compose.prod.yml).
# На своём ПК / в WSL с Postgres из docker-compose.dev.yml ВСЕГДА 127.0.0.1 или localhost.
#
# Локально (npm run dev / npm run db:migrate:dev на машине):
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/tennis1v1
#
# Прод: только в .env для контейнера server (тот же compose, что и postgres):
# DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB
#
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/tennis1v1

# JWT — секретный ключ для подписи токенов (любая длинная случайная строка)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Admin SDK — берётся из Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Вставлять строку целиком с \n — именно так, в кавычках:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=replace_with_private_key_from_json

# Порт сервера
PORT=3000

# Окружение: development | production
NODE_ENV=development

# При NODE_ENV=development (или не production), если PostgreSQL недоступна, гостевые refresh-токены
# временно хранятся в памяти процесса — можно сыграть с ботом без БД. Отключить: DISABLE_DEV_MEMORY_REFRESH=1
# DISABLE_DEV_MEMORY_REFRESH=1
#
# Если NODE_ENV=production (Docker на VPS), а Postgres ещё нет — явно разрешить гостя без БД
# и временный JWT, пока не задан JWT_SECRET:
# ALLOW_OFFLINE_GUEST=1
